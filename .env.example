# Application
NODE_ENV=development
PORT=3000
FRONTEND_URL="http://localhost:5173"

# Database - PostgreSQL
DATABASE_URL="postgresql://lecreuset:lecreuset_secret@localhost:5433/lecreuset?schema=public"
POSTGRES_USER=lecreuset
POSTGRES_PASSWORD=lecreuset_secret
POSTGRES_DB=lecreuset


# Storage Driver (local | minio)
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads

# MinIO - Object Storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=localhost
MINIO_PORT=9002
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=lecreuset-files

# Resend - Email Service
RESEND_API_KEY=
MAIL_FROM="Le Creuset <contact@lagrenaille.fr>"
DOMAIN_NAME=lecreuset.benaja-bendo.fr

# Admin
ADMIN_EMAIL=admin@lecreuset.fr

# SMTP Configuration (Example: Infomaniak)
SMTP_HOST=mail.infomaniak.com
SMTP_PORT=587
SMTP_USER=contact@lagrenaille.fr
SMTP_PASSWORD=
SMTP_SECURE=false

# CORS
CORS_ORIGIN=*

# JWT
JWT_SECRET=super-secret-key-change-this-in-production-123456
JWT_EXPIRES_IN=7d
